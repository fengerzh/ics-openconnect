<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="12dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/oc_surface"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/oc_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/securid_info"
                    android:textColor="@color/oc_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/token_unlock_title"
                    android:textColor="@color/oc_text_primary"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/token_need_devid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/token_need_devid"
                    android:textColor="@color/oc_text_primary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/token_devid_entry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/oc_input_bg"
                    android:inputType="textNoSuggestions"
                    android:padding="16dp"
                    android:textColor="@color/oc_text_primary"
                    android:textColorHint="@color/oc_text_tertiary">

                    <requestFocus />
                </EditText>

                <Space
                    android:id="@+id/token_devid_space"
                    android:layout_width="match_parent"
                    android:layout_height="16dp" />

                <TextView
                    android:id="@+id/token_need_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/token_need_password"
                    android:textColor="@color/oc_text_primary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/token_password_entry"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/oc_input_bg"
                    android:inputType="textPassword|textNoSuggestions"
                    android:padding="16dp"
                    android:textColor="@color/oc_text_primary"
                    android:textColorHint="@color/oc_text_tertiary" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/cancel_button"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:background="@drawable/oc_profile_action_bg"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/oc_text_primary" />

        <Space
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/next_button"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:background="@drawable/oc_disconnect_button_bg"
            android:text="@string/next"
            android:textAllCaps="false"
            android:textColor="@android:color/white" />

    </LinearLayout>

</LinearLayout>
